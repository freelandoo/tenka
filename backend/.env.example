# TENKA Backend — variáveis de ambiente
#
# Local: copie para `.env` e preencha. No Railway, defina como variáveis do
# serviço (DATABASE_URL vem por referência ao plugin Postgres do projeto).

# Postgres. No Railway use a referência: ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tenka

# Porta HTTP. O Railway injeta PORT automaticamente; localmente cai para 8080.
PORT=8080

# Origem(ns) permitida(s) no CORS (domínio do frontend no Vercel).
# Vírgula separa múltiplas. "*" libera geral (só para desenvolvimento).
CORS_ORIGIN=*

# Roda as migrations no boot do servidor. "false" desliga (rode `npm run migrate`).
RUN_MIGRATIONS_ON_BOOT=true

# Segredos de auth (usados a partir da fase F3 — ainda não obrigatórios).
JWT_SECRET=
REFRESH_SECRET=
