# TENKA Painel — variáveis de ambiente (frontend)
#
# Copie para `.env.local` e preencha com os valores do seu projeto Supabase
# (Dashboard → Project Settings → API). Prefixo VITE_ = exposto ao navegador,
# portanto SOMENTE a URL e a chave ANON (pública) entram aqui.
#
# NUNCA coloque a service role key em nenhuma variável VITE_*.
# Ela é usada exclusivamente pela Edge Function `admin-users` no servidor.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica
