# TENKA Painel — variáveis de ambiente (frontend)
#
# Copie para `.env.local` e ajuste conforme o ambiente. Prefixo VITE_ = exposto
# ao navegador; aqui só entra a URL pública do backend (nenhum segredo).

# URL do backend TENKA (Fastify + JWT). Em dev, o padrão é http://localhost:8080
# se esta variável não for definida. Em produção, aponte para o serviço do
# Railway (ex.: https://tenka-backend.up.railway.app).
VITE_API_URL=http://localhost:8080
